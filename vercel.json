{
  "version": 2,
  "builds": [
    {
      "src": "trust.html",
      "use": "@vercel/static"
    },
    {
      "src": "privacy.html",
      "use": "@vercel/static"
    },
    {
      "src": "ao-logo.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "ao-logo-new.png",
      "use": "@vercel/static"
    },
    {
      "src": "favicon-32x32.png",
      "use": "@vercel/static"
    },
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 60 }
    }
  ],
  "routes": [
    {
      "src": "/trust",
      "dest": "/trust.html"
    },
    {
      "src": "/privacy",
      "dest": "/privacy.html"
    },
    {
      "src": "/ao-logo.jpg",
      "dest": "/ao-logo.jpg"
    },
    {
      "src": "/ao-logo-new.png",
      "dest": "/ao-logo-new.png"
    },
    {
      "src": "/favicon-32x32.png",
      "dest": "/favicon-32x32.png"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}
