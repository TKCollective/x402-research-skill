# ── AgentOracle x402 Research API ─────────────────────────────────
# Copy to .env and fill in your values

# Your Base mainnet wallet address (receives USDC/EURC payments)
PAY_TO_ADDRESS=0xYourBaseWalletAddress

# Perplexity API key (get one at https://docs.perplexity.ai)
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: server port (defaults to 3000)
SERVER_PORT=3000

# Optional: facilitator URL (defaults to https://facilitator.xpay.sh)
FACILITATOR_URL=https://facilitator.xpay.sh

# ── Token Addresses (Base mainnet) ───────────────────────────────
# These are hardcoded in index.js but listed here for reference:
# USDC: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# EURC: 0x60a3E35Cc302bFA44Cb288Bc5a4F316Fdb1adb42
