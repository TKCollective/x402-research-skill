# ─── x402 Research API — Environment Variables ───────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server port
SERVER_PORT=3000

# Your Base mainnet wallet address (receives USDC payments)
PAY_TO_ADDRESS=0xYourBaseWalletAddressHere

# Perplexity API key — get one at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# x402 Facilitator URL
# CDP mainnet (recommended): https://api.cdp.coinbase.com/platform/v2/x402
# x402.org testnet only:     https://x402.org/facilitator
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
